# Copy this file to .env and fill in your values.

# --- PostgreSQL ---
POSTGRES_USER=joplin-user
POSTGRES_PASSWORD=randomString4711
POSTGRES_DB=joplindb

# --- Joplin MCP ---
# Retrieve after first run:
#   docker exec joplin-data-api cat /root/joplin/profile/settings.json | grep token
JOPLIN_TOKEN=

# MCP server log level (debug|info|warning|error)
MCP_LOG_LEVEL=info
